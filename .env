# ==============================================================================
# NEON AIR CANVAS - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Title:       Neon Air Canvas
# Description: Advanced hand gesture-based spatial drawing interface utilizing 
#              real-time computer vision, MediaPipe Tasks API, and OpenCV.
#              Features glassmorphic UI, dynamic stroke interpolation, and 
#              neon bloom processing.
# 
# Developer:   Lerik07
# Version:     1.0.0
# Stack:       Python 3.10+, OpenCV, MediaPipe
# ==============================================================================

# --- Application Metadata ---
APP_NAME="Neon Air Canvas"
APP_ENV="production"
APP_VERSION="1.0.0"
AUTHOR="Leirk07"

# --- Engine Configuration (Read-Only Defaults) ---
ENGINE_BACKEND="OpenCV"
TRACKING_MODEL="HandLandmarker (float16)"
TRACKING_CONFIDENCE_MIN=0.7

# --- Display & Graphics Parameters ---
WINDOW_WIDTH=1280
WINDOW_HEIGHT=720
ENABLE_POST_PROCESSING=true
ENABLE_PARTICLE_SYSTEM=true
NEON_BLOOM_KERNEL=21

# --- Brush Configuration ---
BRUSH_SIZE_DEFAULT=8
BRUSH_SIZE_MIN=2
BRUSH_SIZE_MAX=50
ERASER_RADIUS_DEFAULT=40
